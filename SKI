let current=0,answers={},timerInterval=null,timeLeft=90*60,examStarted=false,studentName='',studentNo='';

function createParticles(){const c=document.getElementById('particles');for(let i=0;i<18;i++){const p=document.createElement('div');p.className='particle';const s=30+Math.random()*80;p.style.cssText=`width:${s}px;height:${s}px;left:${Math.random()*100}%;animation-duration:${8+Math.random()*12}s;animation-delay:${Math.random()*10}s;`;c.appendChild(p);}}
createParticles();

function speak(text){if(!('speechSynthesis' in window))return;window.speechSynthesis.cancel();const u=new SpeechSynthesisUtterance(text);u.lang='id-ID';u.rate=0.95;u.pitch=1.2;const trySpeak=()=>{const voices=window.speechSynthesis.getVoices();const v=voices.find(v=>v.lang.startsWith('id'))||null;if(v)u.voice=v;window.speechSynthesis.speak(u);};if(window.speechSynthesis.getVoices().length===0){window.speechSynthesis.onvoiceschanged=trySpeak;}else{trySpeak();}}

function startExam(){studentName=document.getElementById('inp-nama').value.trim();studentNo=document.getElementById('inp-noujian').value.trim();if(!studentName||!studentNo){alert('⚠️ Harap isi Nama dan Nomor Ujian terlebih dahulu!');return;}document.getElementById('cover-page').style.display='none';document.getElementById('quiz-page').style.display='block';try{const el=document.documentElement;if(el.requestFullscreen)el.requestFullscreen().catch(()=>{});}catch(e){}examStarted=true;buildNavDots();renderQuestion();startTimer();setTimeout(()=>{speak('SELAMAT MENGERJAKAN UJIAN MADRASAH, SEMOGA BERHASIL');},800);}

function startTimer(){const el=document.getElementById('timer');timerInterval=setInterval(()=>{timeLeft--;const m=Math.floor(timeLeft/60);const s=timeLeft%60;el.textContent=`${m}:${s<10?'0':''}${s}`;if(timeLeft<=300)el.classList.add('warn');if(timeLeft<=0){clearInterval(timerInterval);submitExam(true);}},1000);}

function buildNavDots(){const nav=document.getElementById('q-nav');nav.innerHTML='';questions.forEach((q,i)=>{const d=document.createElement('div');d.className=`q-dot${q.type==='essay'?' essay-q':''}`;d.textContent=i+1;d.onclick=()=>{current=i;renderQuestion();};nav.appendChild(d);});updateNavDots();}

function updateNavDots(){const dots=document.querySelectorAll('.q-dot');dots.forEach((d,i)=>{d.classList.remove('current','answered');if(i===current)d.classList.add('current');else if(answers[i]!==undefined&&answers[i]!==''){if(Array.isArray(answers[i])&&answers[i].length>0)d.classList.add('answered');else if(!Array.isArray(answers[i])&&answers[i]!=='')d.classList.add('answered');}});}

function renderQuestion(){const q=questions[current];const body=document.getElementById('quiz-body');let badge='';if(current<30)badge=`<div class="section-badge badge-pg">✦ Pilihan Ganda — Soal ${current+1}</div>`;else if(current<40)badge=`<div class="section-badge badge-pgk">◆ Pilihan Ganda Kompleks — Soal ${current+1}</div>`;else badge=`<div class="section-badge badge-essay">✎ Soal Uraian — Soal ${current+1}</div>`;let content='';if(q.type==='radio'){const opts=q.opts.map((opt,i)=>{const sel=answers[current]===i?' selected':'';return`<div class="option-item${sel}" onclick="selectRadio(${i})"><div class="opt-radio"><div class="opt-radio-dot"></div></div><span class="opt-label">${String.fromCharCode(65+i)}. ${opt}</span></div>`;}).join('');content=`<div class="options-list">${opts}</div>`;}else if(q.type==='checkbox'){const hint=`<div class="checkbox-hint">⚠ Pilih 2 jawaban yang benar</div>`;const opts=q.opts.map((opt,i)=>{const sel=(answers[current]||[]).includes(i)?' selected':'';return`<div class="option-item${sel}" onclick="selectCheckbox(${i})"><div class="opt-check">✓</div><span class="opt-label">${String.fromCharCode(65+i)}. ${opt}</span></div>`;}).join('');content=hint+`<div class="options-list">${opts}</div>`;}else if(q.type==='essay'){const val=answers[current]||'';content=`<div class="essay-wrap"><textarea class="essay-textarea" placeholder="Tulis jawaban lengkap Anda di sini..." oninput="saveEssay(this.value)">${val}</textarea></div>`;}const qText=q.text.replace(/\n/g,'<br>');body.innerHTML=`${badge}<p class="q-text">${qText}</p>${content}`;document.getElementById('q-num').textContent=current+1;const pct=((current+1)/questions.length*100).toFixed(1);document.getElementById('progress-fill').style.width=pct+'%';document.getElementById('progress-label').textContent=`${current+1} / ${questions.length} Soal`;const btnPrev=document.getElementById('btn-prev');const btnNext=document.getElementById('btn-next');btnPrev.disabled=current===0;if(current===questions.length-1){btnNext.textContent='KIRIM JAWABAN ✓';btnNext.className='btn-nav btn-submit';}else{btnNext.textContent='LANJUT →';btnNext.className='btn-nav btn-next';}updateNavDots();window.scrollTo({top:0,behavior:'smooth'});}

function selectRadio(idx){answers[current]=idx;renderQuestion();playClick();}
function selectCheckbox(idx){if(!answers[current])answers[current]=[];const pos=answers[current].indexOf(idx);if(pos>-1)answers[current].splice(pos,1);else{if(answers[current].length>=2)answers[current].shift();answers[current].push(idx);}renderQuestion();playClick();}
function saveEssay(val){answers[current]=val;updateNavDots();}
function prevQ(){if(current>0){current--;renderQuestion();}}
function nextQ(){if(current<questions.length-1){current++;renderQuestion();}else{confirmSubmit();}}
function confirmSubmit(){const answered=Object.keys(answers).filter(k=>{const v=answers[k];if(Array.isArray(v))return v.length>0;return v!==undefined&&v!=='';}).length;const unanswered=questions.length-answered;if(confirm(`Apakah Anda yakin ingin mengirim jawaban?\n\n✅ Terjawab: ${answered} soal\n❓ Belum dijawab: ${unanswered} soal`))submitExam(false);}

function submitExam(autoSubmit){clearInterval(timerInterval);let score=0;questions.forEach((q,i)=>{if(q.type==='radio'){if(answers[i]===q.ans)score+=2;}else if(q.type==='checkbox'){const u=(answers[i]||[]).slice().sort().join(',');const c=q.ans.slice().sort().join(',');if(u===c)score+=2;}});const jawaban={};questions.forEach((q,i)=>{if(q.type==='radio'){jawaban[`S${i+1}`]=answers[i]!==undefined?String.fromCharCode(65+answers[i]):'-';}else if(q.type==='checkbox'){jawaban[`S${i+1}`]=(answers[i]||[]).map(x=>String.fromCharCode(65+x)).join(',')||'-';}else{jawaban[`S${i+1}`]=answers[i]||'-';}});const payload={nama:studentName,noUjian:studentNo,skor:score,jawaban:JSON.stringify(jawaban)};document.getElementById('loading-overlay').classList.add('active');const SCRIPT_URL='https://script.google.com/macros/s/AKfycby0OaXJ9riUKP0UxvSM7Od_7-IZBgEzp88OJ-i07xOYbjLVPEPS5Mf47rOOEwZ_OkUV/exec';fetch(SCRIPT_URL,{method:'POST',mode:'no-cors',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)}).then(()=>{showFinish();}).catch(()=>{showFinish();});setTimeout(showFinish,4000);}

function showFinish(){document.getElementById('loading-overlay').classList.remove('active');document.getElementById('quiz-page').style.display='none';document.getElementById('finish-page').style.display='block';setTimeout(()=>{speak('ALHAMDULILLAH SELESAI, KAMU HEBAT');},500);createFinishParticles();}
function createFinishParticles(){const c=document.getElementById('particles');c.innerHTML='';const colors=['#4fffb0','#ffd700','#ff6b6b','#74b9ff','#a29bfe'];for(let i=0;i<30;i++){const p=document.createElement('div');const s=8+Math.random()*12;p.style.cssText=`position:absolute;border-radius:${Math.random()>0.5?'50%':'3px'};width:${s}px;height:${s}px;background:${colors[Math.floor(Math.random()*colors.length)]};left:${Math.random()*100}%;animation:float ${3+Math.random()*4}s linear infinite;animation-delay:${Math.random()*3}s;opacity:0.8;`;c.appendChild(p);}}
function closeApp(){try{if(document.exitFullscreen)document.exitFullscreen();}catch(e){}document.body.innerHTML=`<div style="display:flex;align-items:center;justify-content:center;min-height:100vh;background:#001a10;color:#4fffb0;font-family:Tajawal,sans-serif;text-align:center;padding:20px;"><div><div style="font-size:4rem;margin-bottom:16px;">🕌</div><div style="font-size:1.5rem;font-weight:700;margin-bottom:10px;">TERIMA KASIH</div><div style="color:rgba(232,255,244,0.6);">Silahkan tutup tab ini atau hubungi pengawas.</div></div></div>`;}
function playClick(){try{const ctx=new(window.AudioContext||window.webkitAudioContext)();const osc=ctx.createOscillator();const gain=ctx.createGain();osc.connect(gain);gain.connect(ctx.destination);osc.type='sine';osc.frequency.setValueAtTime(600,ctx.currentTime);osc.frequency.exponentialRampToValueAtTime(800,ctx.currentTime+0.05);gain.gain.setValueAtTime(0.1,ctx.currentTime);gain.gain.exponentialRampToValueAtTime(0.001,ctx.currentTime+0.1);osc.start(ctx.currentTime);osc.stop(ctx.currentTime+0.1);}catch(e){}}
document.addEventListener('contextmenu',e=>e.preventDefault());
document.addEventListener('keydown',e=>{if(examStarted){if(e.key==='F12'||(e.ctrlKey&&e.shiftKey&&['I','J','C'].includes(e.key))||(e.ctrlKey&&e.key==='U')){e.preventDefault();}}});
</script>
